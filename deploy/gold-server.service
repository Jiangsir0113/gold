[Unit]
Description=Gold Tracker FastAPI Server
After=network.target redis.service
Wants=redis.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/gold-server
Environment=PATH=/opt/gold-server/venv/bin
EnvironmentFile=/opt/gold-server/.env
ExecStart=/opt/gold-server/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
